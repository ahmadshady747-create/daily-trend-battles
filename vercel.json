{
  "version": 2,
  "routes": [
    {
      "src": "/battle/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/og/(.*)",
      "dest": "/og/$1"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/data.json",
      "dest": "/data.json"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
