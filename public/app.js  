            "image": {"url": f"attachment://{filename}"},
            "footer": {
                "text": f"Daily Trend Battles • {date_str} • {battle['category']}"
            },
            "fields": [
                {
                    "name": "🅰️ Option A",
                    "value": battle["option_a"],
                    "inline": True,
